<idea-plugin>
    <id>com.bryantjames.ridiculouscoding</id>
    <name>Ridiculous Coding</name>
    <version>97.68</version>
    <vendor email="bryant@bryantjames.com" url="https://github.com/the-jolly-green-bryant/ridiculous-coding-intellij-plugin">Bryant James
    </vendor>
    <description><![CDATA[
        <h1>Ridiculous Coding</h1>
        <div>Make your coding experience in IntelliJ 1000x more ridiculous.</div>
        <div>Source available here: https://github.com/the-jolly-green-bryant/ridiculous-coding-intellij-plugin</div>
        <img src="https://github.com/jotson/ridiculous_coding/raw/main/readme-example.gif" />
    ]]></description>

    <idea-version since-build="143.0"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable groupId="appearance" groupWeight="20" id="ridiculous.coding"
                                 displayName="Ridiculous Coding"
                                 instance="com.bryantjames.ridiculouscoding.PowerModeConfigurable"/>
        <enterHandlerDelegate implementation="com.bryantjames.ridiculouscoding.listeners.EnterHandler"/>
        <typedHandler implementation="com.bryantjames.ridiculouscoding.listeners.TypingHandler"/>
        <postStartupActivity implementation="com.bryantjames.ridiculouscoding.Startup"/>
    </extensions>

    <actions>

        <action id="togglePowerModeIII" class="com.bryantjames.ridiculouscoding.listeners.TogglePowerMode"
                text="Toggle Ridiculous Coding"
                description="Toggle ridiculous mode for Ridiculous Coding">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="shift ctrl alt O"/>
        </action>
        <action id="toggleCaretPowerModeIII" class="com.bryantjames.ridiculouscoding.listeners.ToggleCaretPowerMode"
                text="Toggle Caret Power Mode"
                description="Toggle caret mode for Ridiculous Coding">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>